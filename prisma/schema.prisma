generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  category    String
  year        String
  location    String?
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  coverImage  String
  modelUrl    String?
  showModel   Boolean  @default(true)
  images      Image[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Image {
  id          String  @id @default(cuid())
  url         String
  alt         String?
  description String?
  order       Int     @default(0)
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SiteContent {
  id    String @id @default("default")
  key   String @unique
  value String @default("")
}
